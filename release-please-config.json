{
    "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
    "release-type": "simple",
    "include-component-in-tag": false,
    "packages": {
        ".": {
            "package-name": "munin",
            "extra-files": [
                "Cargo.toml",
                {
                    "type": "json",
                    "path": "crates/munin-binlog-mcp/extension/package.json",
                    "jsonpath": "$.version"
                },
                {
                    "type": "json",
                    "path": "crates/munin-binlog-mcp/extension/package-lock.json",
                    "jsonpath": "$.version"
                },
                {
                    "type": "json",
                    "path": "crates/munin-binlog-mcp/extension/package-lock.json",
                    "jsonpath": "$.packages[''].version"
                }
            ]
        }
    }
}
