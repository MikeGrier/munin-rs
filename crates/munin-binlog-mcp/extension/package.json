{
    "name": "munin-binlog-mcp",
    "displayName": "Munin Binlog MCP",
    "description": "MCP server for querying MSBuild binary log (.binlog) files: errors, warnings, project tree, task timeline, and full event detail -- callable directly from Copilot Chat.",
    "version": "0.1.0",
    "publisher": "MikeGrierTools",
    "license": "MIT",
    "author": {
        "name": "Michael Grier"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/MikeGrier/munin-rs.git",
        "directory": "crates/munin-binlog-mcp/extension"
    },
    "bugs": {
        "url": "https://github.com/MikeGrier/munin-rs/issues"
    },
    "homepage": "https://github.com/MikeGrier/munin-rs/tree/main/crates/munin-binlog-mcp",
    "qna": "https://github.com/MikeGrier/munin-rs/discussions/categories/q-a",
    "engines": {
        "vscode": "^1.101.0"
    },
    "icon": "images/icon.png",
    "galleryBanner": {
        "color": "#1E293B",
        "theme": "dark"
    },
    "categories": [
        "AI",
        "Chat",
        "Other"
    ],
    "keywords": [
        "mcp",
        "model-context-protocol",
        "copilot",
        "msbuild",
        "binlog",
        "build",
        "ai-tools"
    ],
    "activationEvents": [
        "onStartupFinished"
    ],
    "main": "./out/extension.js",
    "contributes": {
        "mcpServerDefinitionProviders": [
            {
                "id": "munin-binlog-mcp",
                "label": "munin-binlog-mcp"
            }
        ],
        "commands": [
            {
                "command": "munin-binlog-mcp.copyServerPath",
                "title": "munin-binlog-mcp: Copy bundled server binary path",
                "category": "munin-binlog-mcp"
            },
            {
                "command": "munin-binlog-mcp.showServerVersion",
                "title": "munin-binlog-mcp: Show bundled server version",
                "category": "munin-binlog-mcp"
            }
        ],
        "configuration": {
            "title": "Munin Binlog MCP",
            "properties": {
                "munin-binlog-mcp.binaryPath": {
                    "type": "string",
                    "default": "",
                    "markdownDescription": "Override the path to the `munin-binlog-mcp` binary. Leave blank to use the binary bundled with the extension. Intended for development against a locally-built `munin-binlog-mcp`."
                },
                "munin-binlog-mcp.extraArgs": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "default": [],
                    "markdownDescription": "Extra command-line arguments passed to the `munin-binlog-mcp` server on startup."
                }
            }
        }
    },
    "scripts": {
        "compile": "tsc -p ./",
        "package": "vsce package"
    },
    "devDependencies": {
        "@types/node": "^22.0.0",
        "@types/vscode": "^1.101.0",
        "typescript": "^5.4.0",
        "@vscode/vsce": "^3.0.0"
    }
}
